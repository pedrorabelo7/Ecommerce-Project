@model IEnumerable<Ecommerce.Domain.Entities.Produto>

@{
    ViewData["Title"] = "Produtos";
}


<h2>Produtos</h2>

@if (Model == null || !Model.Any())
{
    <div class="alert alert-warning">
        Nenhum produto encontrado
    </div>
}

else
{
    <table class="table table-striped">
        <thread>
            <tr>
                <th>Nome</th>
                <th>Descricao</th>
                <th>Preco</th>
                <th>Estoque</th>
            </tr>
        </thread>


        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.Nome</td>
                    <td>@item.Descricao</td>
                    <td>@item.Preco</td>
                    <td>@item.Estoque</td>
                </tr>
            }

        </tbody>
    </table>
}

